# CPA-X 面板示例配置（复制为 .env 后按需修改）
#
# 说明：
# - 推荐先运行：python3 scripts/doctor.py --write-env
# - doctor 会自动探测并补齐 service/config/log/auth 等路径，但不会写入任何明文密钥或面板口令。
# - 下面带 replace-me 的值必须手动改掉，否则安装器和运行时都会拒绝启动。

# 面板端口
CLIPROXY_PANEL_PANEL_PORT=8080

# 面板监听地址（默认局域网可访问；仅本机访问请改成 127.0.0.1）
CLIPROXY_PANEL_BIND_HOST=0.0.0.0

# Waitress worker 线程数
CLIPROXY_PANEL_PANEL_THREADS=8

# 面板管理员口令（必填）
CLIPROXY_PANEL_PANEL_USERNAME=replace-me-admin
CLIPROXY_PANEL_PANEL_PASSWORD=replace-me-with-a-long-random-password

# 可选：额外的 API 访问密钥（兼容 upstream 的 X-Panel-Key / ?panel_key=...）
CLIPROXY_PANEL_PANEL_ACCESS_KEY=

# 主配置写回默认关闭（推荐保持 false）
CLIPROXY_PANEL_CONFIG_WRITE_ENABLED=false

# CLIProxyAPI 管理接口
CLIPROXY_PANEL_CLIPROXY_API_BASE=http://127.0.0.1
CLIPROXY_PANEL_CLIPROXY_API_PORT=8317

# 上游密钥（按你的部署填写）
CLIPROXY_PANEL_MANAGEMENT_KEY=replace-me-with-a-strong-management-key
CLIPROXY_PANEL_MODELS_API_KEY=replace-me-with-a-strong-models-api-key

# 服务与路径（doctor 会尽量自动补齐）
CLIPROXY_PANEL_CLIPROXY_SERVICE=cliproxyapi@freecodex
CLIPROXY_PANEL_CLIPROXY_DIR=/var/lib/cliproxyapi/freecodex
CLIPROXY_PANEL_CLIPROXY_CONFIG=/etc/cliproxyapi/freecodex/config.yaml
CLIPROXY_PANEL_CLIPROXY_BINARY=/usr/local/bin/cliproxyapi
CLIPROXY_PANEL_CLIPROXY_LOG=/var/lib/cliproxyapi/freecodex/auths/logs/main.log
CLIPROXY_PANEL_CLIPROXY_STDERR=/var/log/cliproxy/stderr.log
CLIPROXY_PANEL_AUTH_DIR=/var/lib/cliproxyapi/freecodex/auths

# 自动更新
CLIPROXY_PANEL_AUTO_UPDATE_ENABLED=true
CLIPROXY_PANEL_IDLE_THRESHOLD_SECONDS=900
CLIPROXY_PANEL_AUTO_UPDATE_CHECK_INTERVAL=900

# 手动价格（美元/百万Tokens）
CLIPROXY_PANEL_PRICING_INPUT=0
CLIPROXY_PANEL_PRICING_OUTPUT=0
CLIPROXY_PANEL_PRICING_CACHE=0

# 自动价格同步
CLIPROXY_PANEL_PRICING_AUTO_ENABLED=true
CLIPROXY_PANEL_PRICING_AUTO_SOURCE=openrouter
CLIPROXY_PANEL_PRICING_AUTO_MODEL=

# 可选：提高 GitHub Release 检查限流额度
CLIPROXY_PANEL_GITHUB_TOKEN=
