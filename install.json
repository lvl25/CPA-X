{
  "name": "CPA-X",
  "version": "2.2.0",
  "description": "CLIProxyAPI 管理面板",
  "language": "python",
  "entrypoint": "app.py",
  "env_example": ".env.example",
  "env_examples": [".env.example", ".env.docker.example"],
  "ports": [8080],
  "healthcheck": {
    "path": "/healthz",
    "method": "GET",
    "timeout_seconds": 5
  },
  "docker": {
    "image": "registry.maxsale.vn/tools/cpa-x:v2.2.0",
    "dockerfile": "Dockerfile",
    "compose": "docker-compose.yml",
    "env_example": ".env.docker.example",
    "notes": "Container mode is good for monitoring; auto-update and systemd service control are typically unavailable."
  },
  "install": {
    "venv_dir": ".venv",
    "requirements": "requirements.txt",
    "windows": {
      "steps": [
        "python -m venv .venv",
        ".venv\\Scripts\\activate",
        "pip install -r requirements.txt",
        "copy .env.example .env"
      ],
      "start": "python app.py"
    },
    "linux": {
      "steps": [
        "python3 -m venv .venv",
        "source .venv/bin/activate",
        "pip install -r requirements.txt",
        "cp .env.example .env",
        "python3 scripts/doctor.py --write-env"
      ],
      "start": "python3 app.py",
      "systemd": {
        "service_name": "cliproxy-panel",
        "description": "CLIProxy Management Panel",
        "exec_start": ".venv/bin/python app.py",
        "working_directory": ".",
        "restart": "always",
        "restart_sec": 5
      }
    }
  },
  "scripts": {
    "auto_install": "scripts/auto_install.py",
    "doctor": "scripts/doctor.py",
    "install_sh": "scripts/install.sh",
    "install_ps1": "scripts/install.ps1"
  }
}
