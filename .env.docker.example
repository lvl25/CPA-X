# CPA-X（Docker / 容器部署）示例配置
#
# 用法：
# 1) 复制为 .env（或把这些环境变量写进 docker-compose.yml）
# 2) 按你的宿主机/容器路径修改挂载与路径
#
# 重要：
# - 容器内必须监听 0.0.0.0 才能让端口映射生效
# - 容器模式通常无法使用 systemd，因此“自动更新/服务控制”默认不可用（建议关闭）

CLIPROXY_PANEL_PANEL_USERNAME=replace-me-admin
CLIPROXY_PANEL_PANEL_PASSWORD=replace-me-with-a-long-random-password
CLIPROXY_PANEL_PANEL_ACCESS_KEY=
CLIPROXY_PANEL_BIND_HOST=0.0.0.0
CLIPROXY_PANEL_PANEL_PORT=8080
CLIPROXY_PANEL_PANEL_THREADS=8

# 容器内的面板访问宿主机上的 CLIProxyAPI
CLIPROXY_PANEL_CLIPROXY_API_BASE=http://host.docker.internal
CLIPROXY_PANEL_CLIPROXY_API_PORT=8317

# 上游密钥（如启用才需要）
CLIPROXY_PANEL_MANAGEMENT_KEY=
CLIPROXY_PANEL_MODELS_API_KEY=

# 容器内路径（需要你把宿主机文件挂载到这些位置）
CLIPROXY_PANEL_CLIPROXY_CONFIG=/mnt/cliproxy/config.yaml
CLIPROXY_PANEL_CLIPROXY_LOG=/mnt/cliproxy/main.log
CLIPROXY_PANEL_AUTH_DIR=/mnt/cliproxy/auths

# 容器模式建议关闭自动更新与主配置写回
CLIPROXY_PANEL_AUTO_UPDATE_ENABLED=false
CLIPROXY_PANEL_CONFIG_WRITE_ENABLED=false

# 自动价格同步
CLIPROXY_PANEL_PRICING_AUTO_ENABLED=true
CLIPROXY_PANEL_PRICING_AUTO_SOURCE=openrouter
CLIPROXY_PANEL_PRICING_AUTO_MODEL=
